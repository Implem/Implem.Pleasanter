{
    "name": "wwwroot",
    "private": true,
    "version": "1.5.4",
    "type": "commonjs",
    "scripts": {
        "dev": "concurrently \"npm:watch:scripts\" \"npm:watch:styles\" \"npm:watch:themes\"",
        "watch:themes": "node dev/theme.watch.copy.mjs",
        "watch:scripts": "vite build --config dev/vite.config.scripts.ts --watch --mode development",
        "watch:styles": "node dev/sass.watch.styles.mjs",
        "build": "concurrently --kill-others-on-fail \"tsc\" \"vite build\"",
        "typecheck": "tsc"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@fullcalendar/core": "6.1.20",
        "@types/glidejs__glide": "^3.6.6",
        "@types/jquery": "^3.5.34",
        "@types/jqueryui": "^1.12.24",
        "@types/node": "^25.9.1",
        "concurrently": "^10.0.3",
        "eslint": "^10.4.0",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "prettier-plugin-embed": "^0.5.1",
        "rollup-plugin-copy": "^3.5.0",
        "sass": "^1.100.0",
        "stylelint": "^17.12.0",
        "stylelint-config-recess-order": "^7.7.0",
        "stylelint-config-recommended-scss": "^17.0.1",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
        "stylelint-order": "^8.1.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "7.3.3"
    },
    "dependencies": {
        "@codemirror/autocomplete": "^6.20.2",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-html": "^6.4.11",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/language": "^6.12.3",
        "@codemirror/state": "^6.6.0",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@codemirror/view": "^6.43.0",
        "@glidejs/glide": "^3.7.1",
        "codemirror": "6.0.2",
        "dompurify": "^3.4.6",
        "flatpickr": "^4.6.13",
        "highlight.js": "^11.11.1",
        "jquery": "3.7.1",
        "marked": "^18.0.4",
        "moment": "^2.30.1",
        "suneditor": "^2.47.10"
    },
    "volta": {
        "node": "24.11.1",
        "npm": "11.6.4"
    }
}
